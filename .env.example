# ==============================================================================
# 🔐 CONFIGURACIÓN DE ENTORNO LOCAL (.env)
# ==============================================================================

# -- CONFIGURACIONES DEL SERVICIO DE BÁSCULA (SCALE) --
# Contraseña para acceder al dashboard web de la báscula.
# El Taskfile la convertirá a base64 antes de inyectarla al binario.
SCALE_DASHBOARD_PASSWORD=scale

# Token estático para autenticar clientes API o WebSockets de la báscula.
SCALE_AUTH_TOKEN=scale

# Puerto de red donde escuchará el servicio de la báscula.
SCALE_PORT=8765

# -- CONFIGURACIONES DEL SERVICIO DE TICKETS --
# Contraseña para acceder al dashboard web de tickets.
TICKET_DASHBOARD_PASSWORD=ticket

# Token estático para autenticar clientes API o WebSockets de tickets.
TICKET_AUTH_TOKEN=ticket

# Puerto de red donde escuchará el servicio de tickets.
TICKET_PORT=8766